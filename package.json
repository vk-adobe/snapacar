{
  "name": "snapacar",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "android:start": "expo start --android",
    "prebuild": "expo prebuild",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:link": "node scripts/eas-link-project.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.[jt]s?(x)"],
    "transform": {
      "^.+\\.[jt]sx?$": ["babel-jest", { "configFile": "./babel.config.test.js" }]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-native-community|@expo|expo|react-navigation|@react-navigation)/)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|svg|ttf|otf|woff|woff2)$": "<rootDir>/__mocks__/fileMock.js",
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^react-native/(.*)$": "<rootDir>/__mocks__/emptyModule.js",
      "^@expo/vector-icons$": "<rootDir>/__mocks__/@expo/vector-icons.js",
      "^expo-file-system/legacy$": "<rootDir>/__mocks__/expoFileSystem.js",
      "^expo-file-system$": "<rootDir>/__mocks__/expoFileSystem.js",
      "^expo-image-picker$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo-sharing$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo-constants$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo-crypto$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo-web-browser$": "<rootDir>/__mocks__/expoWebBrowser.js",
      "^expo-auth-session$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo-status-bar$": "<rootDir>/__mocks__/emptyModule.js",
      "^expo$": "<rootDir>/__mocks__/emptyModule.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/asyncStorage.js",
      "^react-native-safe-area-context$": "<rootDir>/__mocks__/emptyModule.js",
      "^react-native-screens$": "<rootDir>/__mocks__/emptyModule.js"
    },
    "setupFiles": ["<rootDir>/jest.setup.js"]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@supabase/supabase-js": "^2.104.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "private": true,
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.10",
    "jest": "^30.3.0",
    "react-test-renderer": "^19.1.0"
  }
}
