# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Web client ID: required for Supabase + Expo; auth-session uses it on Android until you add an
# Android client. Create type "Web application" and type "Android" (package host.exp.exponent for Expo Go).

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
